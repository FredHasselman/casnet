Version: 1.0
ProjectId: ee755f29-88b1-4ef1-b17f-9afc4974021f

RestoreWorkspace: No
SaveWorkspace: No
AlwaysSaveHistory: No

EnableCodeIndexing: Yes
UseSpacesForTab: Yes
NumSpacesForTab: 2
Encoding: UTF-8

RnwWeave: knitr
LaTeX: XeLaTeX

StripTrailingWhitespace: Yes

BuildType: Package
PackageUseDevtools: Yes
PackageInstallArgs: --with-keep.source
PackageBuildArgs: --force
PackageCheckArgs: --as-cran
PackageRoxygenize: rd,collate,namespace,vignette

QuitChildProcessesOnExit: Yes
DisableExecuteRprofile: Yes

ZoteroLibraries: "My Library"
